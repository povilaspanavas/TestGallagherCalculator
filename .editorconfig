root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

[*.{csproj,props,targets,json,js,jsx,ts,tsx,css,html,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.sln]
indent_style = tab
indent_size = tab

[*.md]
trim_trailing_whitespace = false
